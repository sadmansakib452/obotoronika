# ── Database ────────────────────────────────────────────────────────
# Local Supabase (Postgres)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# ── Supabase (production) ───────────────────────────────────────────
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="sb_publishable_your-key"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIs..."
# IMPORTANT: leave this unset to allow Nuxt to derive the correct key
# SUPABASE_STORAGE_KEY=

# ── Supabase Auth - External OAuth Providers ────────────────────────
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID="your-google-client-id"
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET="your-google-secret"

# ── Supabase Auth - Redirect URLs ───────────────────────────────────
SUPABASE_AUTH_SITE_URL="https://your-domain.com"
SUPABASE_AUTH_ADDITIONAL_REDIRECT_URL_1="https://your-domain.com"
SUPABASE_AUTH_ADDITIONAL_REDIRECT_URL_2="https://your-domain.com/auth/callback"
SUPABASE_AUTH_ADDITIONAL_REDIRECT_URL_3="http://localhost:3000/auth/callback"

# ── NuxtHub ─────────────────────────────────────────────────────────
NUXT_HUB_PROJECT_KEY="your-hub-project-key"
BASE_URL="https://your-domain.com"

# ── Cloudflare ──────────────────────────────────────────────────────
CLOUDFLARE_ZONE_ID="your-zone-id"
CLOUDFLARE_API_TOKEN="your-api-token"

# ── SSLCommerz (Payment Gateway) ────────────────────────────────────
STORE_ID="your-store-id"
STORE_PASSWORD="your-store-password"

# ── Dev super admin ─────────────────────────────────────────────────
# IMPORTANT: keep these local; do not commit `.env`.
SUPER_ADMIN_EMAIL="admin@example.com"
SUPER_ADMIN_PASSWORD="change-me"

# ── Email — Resend (primary) ────────────────────────────────────────
RESEND_API_KEY="re_..."

# ── Email — SMTP (fallback when RESEND_API_KEY is not set) ──────────
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-user@example.com"
SMTP_PASS="your-smtp-password"

# ── Media (Image Hosting) ────────────────────────────────────────────
MEDIA_URL="https://media.your-domain.com"

# ── Vite ─────────────────────────────────────────────────────────────
# Comma-separated additional hosts for Vite dev server
ALLOWED_HOSTS="your-domain.com,db.your-domain.com"

# ── Environment ─────────────────────────────────────────────────────
NODE_ENV=development
